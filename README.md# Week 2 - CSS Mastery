}

.contact-form{
    background:white;
    padding:30px;
    border-radius:var(--radius);
    box-shadow:var(--shadow);
}

.contact-info{
    background:var(--color-primary);
    color:white;
    padding:30px;
    border-radius:var(--radius);
}

.contact-info h2,
.contact-info h3,
.contact-info p{
    color:white;
}

.contact-form label{
    display:block;
    margin-bottom:8px;
    font-weight:600;
}

.contact-form input,
.contact-form select,
.contact-form textarea{

    width:100%;

