}

.footer-links{

    list-style:none;

}

.footer-links li{

    margin-bottom:10px;

}

.footer-links a{

    color:#e2e8f0;

}

.footer-links a:hover{

    color:var(--color-secondary);

}

.footer-copyright{

    text-align:center;

