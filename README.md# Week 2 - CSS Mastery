.navbar {
    display: flex;
    justify-content: space-between; /* Pushes logo left, links right */
    align-items: center;            /* Vertically centers everything */
    background-color: var(--color-primary);
    padding: 20px;
    flex-wrap: wrap;                /* Wraps nicely on tiny phone screens */
}

.logo {
    color: white;
    font-size: 1.8rem;
    font-weight: bold;
}

.nav-links {
    display: flex;                  /* Makes links sit side-by-side */
    gap: 20px;                      /* Even spacing between items */
    list-style: none;               /* Removes list dots */
    margin: 0;                      /* Clears default browser space */
    padding: 0;                     /* Clears default browser padding */
}

/* Make text readable on the blue background */
.nav-links a {
    color: white;
}

.nav-links a:hover {
    color: var(--color-secondary);  /* Turns orange when hovered! */
}

