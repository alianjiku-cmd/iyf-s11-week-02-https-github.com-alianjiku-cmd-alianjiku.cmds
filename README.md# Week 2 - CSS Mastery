**THIS IS MY box-model-practice.html**
        
*{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:Arial, sans-serif;
            background:#f8fafc;
            color:#1e293b;
            padding:40px;
            line-height:1.6;
        }

        h1,h2{
            text-align:center;
            margin-bottom:20px;
        }

        section{
            margin-bottom:60px;
        }

        /* =========================
        BOX MODEL VISUALIZATION
        ========================= */

        .box-container{
            display:flex;
            flex-wrap:wrap;
            gap:20px;
            justify-content:center;
        }

        .box{

            width:220px;

            padding:20px;

            border:5px solid #2563eb;

            margin:20px;

            background:#bfdbfe;

            text-align:center;

        }

        /* =========================
        BROKEN BOX (FIXED)
        ========================= */

        .broken-box{

            width:300px;

            padding:20px;

            border:2px solid gray;

            background:white;

            margin:auto;

            text-align:center;

        }

        /* =========================
        CARD COMPONENT
        ========================= */

        .card{

            width:300px;

            margin:auto;

            border:1px solid gray;

            border-radius:10px;

            overflow:hidden;

            background:white;

            box-shadow:0 5px 15px rgba(0,0,0,.1);

        }

        .card img{

            width:100%;

            display:block;

        }

        .card-content{

            padding:20px;

        }

        .card h3{

            margin-bottom:15px;

        }

        .card p{

            margin-bottom:20px;

        }

        .button{

            display:inline-block;

            background:#2563eb;

            color:white;

            padding:10px 20px;

            text-decoration:none;

            border-radius:6px;

        }

        .button:hover{

            background:#1d4ed8;

        }

    </style>

</head>

